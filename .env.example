# ============================================
# 通知通道配置
# ============================================

# 通知通道选择（默认：email）
# Trending digest 可选值：email, wechat
# AI Developer Radar 推荐使用：feishu
# 多通道用逗号分隔，如：email,wechat
NOTIFIER_CHANNELS=email

# ============================================
# Email 配置
# ============================================

SMTP_USER=your@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
MAIL_FROM=your@qq.com
TRENDING_EMAIL_TO=your@gmail.com

# ============================================
# 微信（WeClaw，本地桥接到个人微信）
# ============================================

# WeClaw API 地址（默认可省略：http://127.0.0.1:18011/api/send）
WECLAW_API_URL=http://127.0.0.1:18011

# 接收方微信 ID，例如：filehelper@im.wechat 或 xxx@im.wechat
WECHAT_TO=

# ============================================
# 飞书机器人（AI Developer Radar）
# ============================================

FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
GITHUB_TOKEN=

# ============================================
# Product Hunt API（Launch/Product Signals）
# ============================================

PRODUCT_HUNT_TOKEN=
PRODUCT_HUNT_ENABLED=true
PRODUCT_HUNT_POST_LIMIT=30
PRODUCT_HUNT_DAYS_BACK=1
PRODUCT_HUNT_TOPICS=artificial-intelligence,developer-tools,open-source,productivity,saas
PRODUCT_HUNT_KEYWORDS=ai,llm,agent,rag,mcp,coding,developer,devtool,automation,workflow,open source,api,sdk
PRODUCT_HUNT_MIN_VOTES=10
PRODUCT_HUNT_MIN_COMMENTS=0

# ============================================
# 多源 AI Trend Radar 免费源配置
# ============================================

AIHOT_ENABLED=true
AIHOT_ENDPOINT=https://aihot.virxact.com/
AIHOT_LIMIT=30
AIHOT_CATEGORIES=models,products,papers,industry,tools

HUGGINGFACE_MODELS_ENABLED=true
HUGGINGFACE_MODELS_LIMIT=30
HUGGINGFACE_SPACES_ENABLED=true
HUGGINGFACE_SPACES_LIMIT=30

HACKERNEWS_ENABLED=true
HACKERNEWS_LISTS=topstories,newstories,beststories
HACKERNEWS_LIMIT_PER_LIST=30

# ============================================
# 个性化配置
# ============================================

TRENDING_PROFILE_NOTE=
TRENDING_PROFILE_KEYWORDS=
TRENDING_REPO_LIMIT=10
TRENDING_RECOMMENDATION_LIMIT=5

# ============================================
# AI Developer Radar 配置
# ============================================

RADAR_REPO_LIMIT=100
RADAR_RECOMMENDATION_LIMIT=10
RADAR_DAILY_STAR_THRESHOLD=50
RADAR_EARLY_SIGNAL_DAILY_THRESHOLD=20
RADAR_EARLY_SIGNAL_WEEKLY_THRESHOLD=80
RADAR_PROFILE_KEYWORDS=
RADAR_STORE_PATH=data/radar-store.json
RADAR_USE_SAMPLE_DATA=false

# ============================================
# DeepSeek LLM Enrichment（可选）
# ============================================

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_ENRICHMENT_ENABLED=true
LLM_ENRICHMENT_LIMIT=10
LLM_README_MAX_CHARS=12000
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2
LLM_MAX_OUTPUT_TOKENS=1200
