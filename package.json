{
  "name": "github-trending-radar",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "bin": {
    "github-trending-radar": "./bin/cli.js",
    "gtr": "./bin/cli.js"
  },
  "scripts": {
    "digest:dry-run": "tsx scripts/send-trending-digest.ts --dry-run",
    "digest:send": "tsx scripts/send-trending-digest.ts",
    "radar:baseline": "tsx scripts/send-ai-developer-radar.ts --mode=daily --dry-run --baseline",
    "radar:daily:dry-run": "tsx scripts/send-ai-developer-radar.ts --mode=daily --dry-run",
    "radar:daily:send": "tsx scripts/send-ai-developer-radar.ts --mode=daily --send",
    "radar:daily:generate": "tsx scripts/generate-ai-developer-radar-digest.ts",
    "radar:daily:generate-and-send": "tsx scripts/generate-ai-developer-radar-digest.ts --send",
    "frontend:sync-data": "mkdir -p \"frontend/Align Project Features and Plan/public/data\" && cp data/latest-daily-dashboard.json \"frontend/Align Project Features and Plan/public/data/latest-daily-dashboard.json\"",
    "frontend:build": "cd \"frontend/Align Project Features and Plan\" && npm install && npm run build",
    "cloudflare:deploy": "pnpm frontend:sync-data && pnpm frontend:build && npx wrangler deploy",
    "radar:weekly:dry-run": "tsx scripts/send-ai-developer-radar.ts --mode=weekly --dry-run",
    "radar:weekly:send": "tsx scripts/send-ai-developer-radar.ts --mode=weekly --send",
    "radar:daily:sample": "RADAR_USE_SAMPLE_DATA=true tsx scripts/send-ai-developer-radar.ts --mode=daily --dry-run",
    "radar:daily:generate:sample": "RADAR_USE_SAMPLE_DATA=true tsx scripts/generate-ai-developer-radar-digest.ts",
    "radar:weekly:sample": "RADAR_USE_SAMPLE_DATA=true tsx scripts/send-ai-developer-radar.ts --mode=weekly --dry-run",
    "intelligence:daily": "tsx scripts/generate-intelligence-brief.ts",
    "intelligence:daily:sample": "RADAR_USE_SAMPLE_DATA=true tsx scripts/generate-intelligence-brief.ts",
    "intelligence:lightweight": "tsx scripts/generate-lightweight-intelligence-digest.ts",
    "rss:generate": "tsx scripts/generate-rss-feed.ts",
    "archive:generate": "tsx scripts/generate-digest-archive.ts",
    "subscribers:sync": "tsx scripts/sync-subscribers.ts",
    "subscribers:send": "tsx scripts/sync-subscribers.ts --send",
    "feedback": "tsx scripts/send-trending-digest.ts feedback --stats",
    "producthunt:dry-run": "tsx scripts/send-producthunt-digest.ts --dry-run",
    "producthunt:json": "tsx scripts/send-producthunt-digest.ts --format=json",
    "worker:feishu:typecheck": "tsc --noEmit --pretty false -p workers/feishu-pusher/tsconfig.json",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "node --import tsx --test tests/*.test.ts tests/**/*.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "cheerio": "^1.1.2",
    "citty": "^0.2.1",
    "domhandler": "^6.0.1",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.4",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/nodemailer": "^7.0.2",
    "typescript": "^5.9.2"
  }
}
